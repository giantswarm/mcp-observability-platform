{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "affinity": {
            "type": "object"
        },
        "autoscaling": {
            "type": "object",
            "properties": {
                "hpa": {
                    "type": "object",
                    "properties": {
                        "behavior": {
                            "type": "object"
                        },
                        "enabled": {
                            "type": "boolean"
                        },
                        "maxReplicas": {
                            "type": "integer"
                        },
                        "minReplicas": {
                            "type": "integer"
                        },
                        "targetCPUUtilizationPercentage": {
                            "type": "integer"
                        },
                        "targetMemoryUtilizationPercentage": {
                            "type": "integer"
                        }
                    }
                },
                "vpa": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "resourcePolicy": {
                            "type": "object"
                        },
                        "updateMode": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "containerSecurityContext": {
            "type": "object",
            "properties": {
                "allowPrivilegeEscalation": {
                    "type": "boolean"
                },
                "capabilities": {
                    "type": "object",
                    "properties": {
                        "drop": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "readOnlyRootFilesystem": {
                    "type": "boolean"
                }
            }
        },
        "extraEnvFrom": {
            "type": "array"
        },
        "extraEnvVars": {
            "type": "array"
        },
        "fullnameOverride": {
            "type": "string"
        },
        "grafana": {
            "type": "object",
            "properties": {
                "authMode": {
                    "type": "string"
                },
                "existingSecret": {
                    "type": "string"
                },
                "publicUrl": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "image": {
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "imagePullSecrets": {
            "type": "array"
        },
        "mcp": {
            "type": "object",
            "properties": {
                "debug": {
                    "type": "boolean"
                },
                "transport": {
                    "type": "string"
                }
            }
        },
        "nameOverride": {
            "type": "string"
        },
        "networkPolicy": {
            "type": "object",
            "properties": {
                "egressTo": {
                    "type": "array"
                },
                "enabled": {
                    "type": "boolean"
                },
                "ingressFrom": {
                    "type": "array"
                }
            }
        },
        "nodeSelector": {
            "type": "object"
        },
        "oauth": {
            "type": "object",
            "properties": {
                "allowInsecureHTTP": {
                    "type": "boolean"
                },
                "allowPublicClientRegistration": {
                    "type": "boolean"
                },
                "dex": {
                    "type": "object",
                    "properties": {
                        "clientId": {
                            "type": "string"
                        },
                        "existingSecret": {
                            "type": "string"
                        },
                        "issuerUrl": {
                            "type": "string"
                        }
                    }
                },
                "encryption": {
                    "type": "object",
                    "properties": {
                        "existingSecret": {
                            "type": "string"
                        }
                    }
                },
                "issuer": {
                    "type": "string"
                },
                "storage": {
                    "type": "object",
                    "properties": {
                        "backend": {
                            "type": "string"
                        },
                        "valkey": {
                            "type": "object",
                            "properties": {
                                "addr": {
                                    "type": "string"
                                },
                                "existingSecret": {
                                    "type": "string"
                                },
                                "tls": {
                                    "type": "boolean"
                                }
                            }
                        }
                    }
                }
            }
        },
        "otel": {
            "type": "object",
            "properties": {
                "endpoint": {
                    "type": "string"
                },
                "extraEnv": {
                    "type": "array"
                },
                "insecure": {
                    "type": "boolean"
                },
                "protocol": {
                    "type": "string"
                }
            }
        },
        "podAnnotations": {
            "type": "object"
        },
        "podDisruptionBudget": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "minAvailable": {
                    "type": "integer"
                }
            }
        },
        "podLabels": {
            "type": "object"
        },
        "podSecurityContext": {
            "type": "object",
            "properties": {
                "runAsGroup": {
                    "type": "integer"
                },
                "runAsNonRoot": {
                    "type": "boolean"
                },
                "runAsUser": {
                    "type": "integer"
                },
                "seccompProfile": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "priorityClassName": {
            "type": "string"
        },
        "rbac": {
            "type": "object",
            "properties": {
                "create": {
                    "type": "boolean"
                }
            }
        },
        "replicas": {
            "type": "integer"
        },
        "resources": {
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "runtime": {
            "type": "object",
            "properties": {
                "maxResponseBytes": {
                    "type": "integer"
                },
                "oauthRefreshAhead": {
                    "type": "string"
                },
                "rateLimit": {
                    "type": "object",
                    "properties": {
                        "global": {
                            "type": "integer"
                        },
                        "perCaller": {
                            "type": "integer"
                        },
                        "perOrg": {
                            "type": "integer"
                        }
                    }
                },
                "resolverCacheTTL": {
                    "type": "string"
                },
                "toolTimeout": {
                    "type": "string"
                }
            }
        },
        "service": {
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object"
                },
                "mcpPort": {
                    "type": "integer"
                },
                "metricsPort": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object"
                },
                "create": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "serviceMonitor": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "interval": {
                    "type": "string"
                },
                "labels": {
                    "type": "object",
                    "properties": {
                        "observability.giantswarm.io/tenant": {
                            "type": "string"
                        }
                    }
                },
                "metricRelabelings": {
                    "type": "array"
                },
                "relabelings": {
                    "type": "array"
                }
            }
        },
        "tolerations": {
            "type": "array"
        },
        "topologySpreadConstraints": {
            "type": "array"
        }
    }
}
